# Variáveis de Ambiente - GestaoELMO

# ===== SERVIDOR =====
PORT=5000
NODE_ENV=development
LOG_LEVEL=debug

# ===== BANCO DE DADOS =====
MONGODB_URI=mongodb://admin:admin123@mongo:27017/gestao-estoque
MONGODB_USER=admin
MONGODB_PASS=admin123

# ===== JWT =====
JWT_SECRET=sua_chave_secreta_super_segura_aqui_mude_em_producao
JWT_EXPIRATION=7d

# ===== EMAIL (Gmail/SMTP) =====
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu-email@gmail.com
EMAIL_PASS=sua-senha-app-google
EMAIL_FROM=noreply@gestao-elmo.com

# Alternativa: SendGrid
# SENDGRID_API_KEY=sua-chave-sendgrid

# ===== REDIS (Cache) =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== LIMITES E THRESHOLDS =====
LOW_STOCK_THRESHOLD=0.2
HIGH_STOCK_THRESHOLD=0.9

# ===== CORS =====
CORS_ORIGIN=http://localhost:3000,http://localhost:5000

# ===== LOGGING =====
LOG_FORMAT=json
LOG_DIRECTORY=./logs

# ===== AMBIENTE =====
API_VERSION=v1
API_PREFIX=/api
